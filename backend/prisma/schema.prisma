// Social Fit - Prisma Schema
// User, Post, Group, Message, Streak, Badge, Booking, Subscription

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  emailVerified Boolean   @default(false) @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  profile    Profile?
  posts      Post[]
  likes      Like[]
  savedPosts SavedPost[]
  comments   Comment[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  friendshipsInit  Friendship[] @relation("FriendshipInit")
  friendshipsRecv  Friendship[] @relation("FriendshipRecv")
  groupMembers GroupMember[]
  streaks     Streak[]
  userBadges  UserBadge[]
  bookings    Booking[]
  subscription Subscription?
  starTransactions   StarTransaction[]
  foodLogs           FoodLog[]
  passwordResetTokens PasswordResetToken[]
  notificationsReceived Notification[] @relation("NotifReceiver")
  notificationsSent     Notification[] @relation("NotifSender")
}

model Profile {
  id                   String    @id @default(uuid())
  userId               String    @unique @map("user_id")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName          String    @map("display_name")
  avatarUrl            String?   @map("avatar_url")
  weightKg             Float?    @map("weight_kg")
  heightCm             Float?    @map("height_cm")
  dailyCalorieGoal     Int?      @map("daily_calorie_goal")
  goalNote             String?   @map("goal_note")
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")
  goal                 String?   // lose_weight | gain_muscle | eat_healthy | stay_active
  age                  Int?
  gender               String?
  onboardingData       String?   @map("onboarding_data") // JSON string (SQLite)
  kvkkConsentAt        DateTime? @map("kvkk_consent_at")
  isPublic             Boolean   @default(true) @map("is_public")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  fromUserId String?  @map("from_user_id")
  type       String   // like | follow_request | follow_accepted
  postId     String?  @map("post_id")
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation("NotifReceiver", fields: [userId], references: [id], onDelete: Cascade)
  fromUser   User?    @relation("NotifSender", fields: [fromUserId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model Post {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId   String?  @map("group_id")
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  type      String   // "meal" | "workout"
  imageUrl  String?  @map("image_url")
  caption   String?
  tags      String   // JSON array string (SQLite)
  metadata  String?  // JSON string (SQLite)
  viewCount Int      @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  likes    Like[]
  savedBy  SavedPost[]
  comments Comment[]
}

model Like {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@map("likes")
}

model SavedPost {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, postId])
  @@map("saved_posts")
}

model Comment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("comments")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?  @map("image_url")
  latitude    Float?
  longitude   Float?
  locationName String?  @map("location_name")
  isPrivate   Boolean  @default(false) @map("is_private")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members GroupMember[]
  posts   Post[]
}

model GroupJoinRequest {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  groupId   String   @map("group_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, groupId])
  @@map("group_join_requests")
}

model GroupMember {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId   String   @map("group_id")
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role      String   @default("member") // member | admin
  joinedAt  DateTime @default(now()) @map("joined_at")

  @@unique([userId, groupId])
  @@map("group_members")
}

model Message {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String  @map("receiver_id")
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  body       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation("FriendshipInit", fields: [userId], references: [id], onDelete: Cascade)
  friendId  String   @map("friend_id")
  friend    User     @relation("FriendshipRecv", fields: [friendId], references: [id], onDelete: Cascade)
  status    String   @default("pending") // pending | accepted
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, friendId])
  @@map("friendships")
}

model Streak {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime // gün bazlı (sadece tarih)
  count     Int      @default(1) // ardışık gün sayısı
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, date])
  @@map("streaks")
}

model Badge {
  id          String   @id @default(uuid())
  key         String   @unique // "streak_7" | "streak_14" | "streak_30"
  name        String
  description String?
  iconUrl     String?  @map("icon_url")
  daysRequired Int     @map("days_required")

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String   @map("badge_id")
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now()) @map("earned_at")

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Coach {
  id          String   @id @default(uuid())
  displayName String   @map("display_name")
  bio         String?
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")

  bookings Booking[]
}

model Booking {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coachId   String   @map("coach_id")
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  slotAt    DateTime @map("slot_at")
  status    String   @default("pending") // pending | confirmed | completed | cancelled
  createdAt DateTime @default(now()) @map("created_at")

  @@map("bookings")
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      String   @default("premium") // free | premium
  startsAt DateTime @map("starts_at")
  endsAt   DateTime @map("ends_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("subscriptions")
}

model StarTransaction {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  points    Int
  reason    String   // post_created | comment_created | like_received | group_joined | friend_added | profile_completed | coach_booked | streak_daily
  refId     String?  @map("ref_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("star_transactions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   // 6 haneli OTP
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

model FoodLog {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  date      DateTime
  mealType  String   @map("meal_type") // breakfast | lunch | dinner | snack
  foodName  String   @map("food_name")
  calories  Int
  protein   Float?
  carbs     Float?
  fat       Float?
  imageUrl  String?  @map("image_url")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("food_logs")
}

model Recipe {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  category    String
  tags        String   @default("[]")
  timeMinutes Int      @map("time_minutes")
  calories    Int
  protein     Float
  carbs       Float
  fat         Float
  servings    Int      @default(1)
  difficulty  String   @default("Kolay")
  imageUrl    String?  @map("image_url")
  ingredients String
  steps       String
  fitNote     String?  @map("fit_note")
  fullText    String?  @map("full_text")
  isFeatured  Boolean  @default(false) @map("is_featured")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("recipes")
}
