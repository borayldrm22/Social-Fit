# ─── Veritabanı (Supabase PostgreSQL — dev+prod) ─────────────
#   DATABASE_URL = "pooled" bağlantı (pgBouncer, port 6543, sonuna ?pgbouncer=true)
#   DIRECT_URL   = "direct" bağlantı (port 5432, migration/db push için)
#   ⚠️ DIRECT_URL sonunda ?sslmode=require ŞART — Supabase self-signed cert;
#      eksikse `prisma db push` P1001 (can't reach) ile düşer.
DATABASE_URL="postgresql://postgres.<ref>:<PW>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<PW>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────
# ZORUNLU. Güçlü rastgele değer üret: openssl rand -base64 48
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ─── Sunucu ───────────────────────────────────────────────────
PORT=4000
BASE_URL=http://localhost:4000
# Prod'da izin verilen origin'ler (virgülle ayır). Boşsa dev = tüm origin'ler.
# CORS_ORIGINS=https://app.socialfit.com

# ─── Dosya depolama ───────────────────────────────────────────
# Bu iki değer BOŞSA yüklemeler yerel diske (UPLOAD_DIR) gider — dev için yeterli.
# DOLUYSA Supabase Storage kullanılır (prod'da zorunlu; Render diski kalıcı değil).
UPLOAD_DIR=./uploads
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_KEY=<service_role anahtarı — ASLA mobile'a koyma, sadece sunucu>
# SUPABASE_BUCKET=uploads
